<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Activity Simulator Report — {{ session_id }}</title>
    <style>
        :root {
            --bg-primary: #1a1a2e;
            --bg-secondary: #16213e;
            --bg-card: #0f3460;
            --text-primary: #e0e0e0;
            --text-secondary: #a0a0b0;
            --accent: #e94560;
            --accent-secondary: #4a90d9;
            --success: #4caf50;
            --warning: #ff9800;
            --error: #f44336;
            --border: rgba(255, 255, 255, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            padding: 2rem;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 2rem;
            padding: 2rem;
            background: linear-gradient(135deg, var(--bg-secondary), var(--bg-card));
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .header h1 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--accent), var(--accent-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .header .badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: var(--accent);
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 0.5rem;
        }

        .header .meta {
            color: var(--text-secondary);
            font-size: 0.9rem;
            margin-top: 0.5rem;
        }

        /* Cards Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .stat-card {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.25rem;
            text-align: center;
            transition: transform 0.2s;
        }

        .stat-card:hover {
            transform: translateY(-2px);
        }

        .stat-card .value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--accent-secondary);
        }

        .stat-card .label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-top: 0.25rem;
        }

        .stat-card.success .value { color: var(--success); }
        .stat-card.error .value { color: var(--error); }
        .stat-card.warning .value { color: var(--warning); }

        /* Sections */
        .section {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .section h2 {
            font-size: 1.2rem;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid var(--border);
            color: var(--accent-secondary);
        }

        /* Tables */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        th, td {
            padding: 0.65rem 1rem;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            background: rgba(74, 144, 217, 0.1);
            color: var(--accent-secondary);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
        }

        tr:hover {
            background: rgba(255, 255, 255, 0.03);
        }

        /* Charts */
        .chart-container {
            text-align: center;
            margin: 1rem 0;
        }

        .chart-container img {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
        }

        /* Error log */
        .error-item {
            background: rgba(244, 67, 54, 0.1);
            border-left: 3px solid var(--error);
            padding: 0.75rem 1rem;
            margin-bottom: 0.5rem;
            border-radius: 0 6px 6px 0;
            font-size: 0.85rem;
        }

        .error-item .error-time {
            color: var(--text-secondary);
            font-size: 0.75rem;
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 1.5rem;
            color: var(--text-secondary);
            font-size: 0.8rem;
            border-top: 1px solid var(--border);
            margin-top: 2rem;
        }

        .footer strong {
            color: var(--accent);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>Developer Activity Simulator — Report</h1>
            <span class="badge">TEST HARNESS</span>
            <div class="meta">
                Session: <strong>{{ session_id }}</strong> |
                Generated: {{ stats.report_generated_at }}
            </div>
        </div>

        <!-- Summary Statistics Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="value">{{ stats.total_runtime_formatted }}</div>
                <div class="label">Total Runtime</div>
            </div>
            <div class="stat-card">
                <div class="value">{{ stats.total_events }}</div>
                <div class="label">Total Events</div>
            </div>
            <div class="stat-card success">
                <div class="value">{{ stats.successful_events }}</div>
                <div class="label">Successful</div>
            </div>
            <div class="stat-card error">
                <div class="value">{{ stats.failed_events }}</div>
                <div class="label">Failed</div>
            </div>
            <div class="stat-card warning">
                <div class="value">{{ stats.idle_duration_seconds }}s</div>
                <div class="label">Idle Duration</div>
            </div>
            <div class="stat-card">
                <div class="value">{{ stats.total_errors }}</div>
                <div class="label">Errors</div>
            </div>
        </div>

        <!-- Activity Distribution -->
        {% if stats.activity_counts %}
        <div class="section">
            <h2>Activity Breakdown</h2>
            <table>
                <thead>
                    <tr>
                        <th>Event Type</th>
                        <th>Count</th>
                        <th>Percentage</th>
                    </tr>
                </thead>
                <tbody>
                    {% for event_type, count in stats.activity_counts.items() %}
                    <tr>
                        <td>{{ event_type }}</td>
                        <td>{{ count }}</td>
                        <td>{{ "%.1f"|format(count / stats.total_events * 100) }}%</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- Charts -->
        {% if charts %}
        <div class="section">
            <h2>Visual Analytics</h2>

            {% if charts.activity_distribution %}
            <div class="chart-container">
                <img src="data:image/png;base64,{{ charts.activity_distribution }}"
                     alt="Activity Distribution Chart">
            </div>
            {% endif %}

            {% if charts.action_frequency %}
            <div class="chart-container">
                <img src="data:image/png;base64,{{ charts.action_frequency }}"
                     alt="Action Frequency Chart">
            </div>
            {% endif %}

            {% if charts.timeline %}
            <div class="chart-container">
                <img src="data:image/png;base64,{{ charts.timeline }}"
                     alt="Activity Timeline Chart">
            </div>
            {% endif %}
        </div>
        {% endif %}

        <!-- Application Involvement -->
        {% if stats.application_counts %}
        <div class="section">
            <h2>Application Involvement</h2>
            <table>
                <thead>
                    <tr>
                        <th>Application</th>
                        <th>Events</th>
                    </tr>
                </thead>
                <tbody>
                    {% for app, count in stats.application_counts.items() %}
                    <tr>
                        <td>{{ app }}</td>
                        <td>{{ count }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- Error Log -->
        {% if stats.error_events %}
        <div class="section">
            <h2>Error Log ({{ stats.total_errors }} total)</h2>
            {% for error in stats.error_events %}
            <div class="error-item">
                <div class="error-time">{{ error.timestamp }}</div>
                <strong>{{ error.event_type }}</strong> — {{ error.action }}
                {% if error.error_message %}
                <br>{{ error.error_message }}
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        <!-- Configuration -->
        {% if stats.config %}
        <div class="section">
            <h2>Configuration Used</h2>
            <table>
                <thead>
                    <tr>
                        <th>Parameter</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    {% for key, value in stats.config.items() %}
                    <tr>
                        <td>{{ key }}</td>
                        <td>{{ value }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

        <!-- Footer -->
        <div class="footer">
            Report generated by <strong>Developer Activity Simulator — TEST HARNESS</strong><br>
            This tool is intended solely for QA, testing, benchmarking, and validation purposes.
        </div>
    </div>
</body>
</html>

# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of microservices, YMMV.
#   Pipfile.lock

# poetry
#   According to poetry docs, the lock file should be committed to version control.
#   poetry.lock

# pdm
#   According to pdm docs, the lock file should be committed to version control.
#   pdm.lock

# PEP 582; project local imports directory (used by pdm)
